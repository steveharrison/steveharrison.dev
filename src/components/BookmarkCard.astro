---
interface Props {
  url: string;
  title: string;
  description?: string;
  thumbnail?: string;
  icon?: string;
  publisher?: string;
}

const { url, title, description, thumbnail, icon, publisher } = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="bookmark-card"
>
  <div class="bookmark-content">
    <div class="bookmark-header">
      <h4 class="bookmark-title">{title}</h4>
    </div>
    {description && <p class="bookmark-description">{description}</p>}
    <div class="bookmark-metadata">
      {icon && <img src={icon} alt="" class="bookmark-icon" />}
      {publisher && <span class="bookmark-publisher">{publisher}</span>}
    </div>
  </div>
  {thumbnail && (
    <div class="bookmark-thumbnail">
      <img src={thumbnail} alt={title} />
    </div>
  )}
</a>

<style>
  .bookmark-card {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
    overflow: hidden;
    margin: 1.5rem 0;
  }

  .bookmark-card:hover {
    border-color: #9ca3af;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  .bookmark-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }

  .bookmark-header {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .bookmark-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    color: #111827;
  }

  .bookmark-description {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #6b7280;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bookmark-metadata {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #9ca3af;
  }

  .bookmark-icon {
    width: 1rem;
    height: 1rem;
    object-fit: contain;
  }

  .bookmark-publisher {
    font-size: 0.75rem;
  }

  .bookmark-thumbnail {
    flex-shrink: 0;
    width: 200px;
    height: 120px;
    overflow: hidden;
    border-radius: 0.375rem;
  }

  .bookmark-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 640px) {
    .bookmark-card {
      flex-direction: column;
    }

    .bookmark-thumbnail {
      width: 100%;
      height: 180px;
    }
  }

  @media (prefers-color-scheme: dark) {
    .bookmark-card {
      border-color: #374151;
    }

    .bookmark-card:hover {
      border-color: #6b7280;
    }

    .bookmark-title {
      color: #f9fafb;
    }

    .bookmark-description {
      color: #d1d5db;
    }

    .bookmark-metadata {
      color: #6b7280;
    }
  }
</style>
